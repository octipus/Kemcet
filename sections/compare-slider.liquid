          "label": "t:sections.compare_slider.blocks.image-before-slide.settings.image.content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.compare_slider.blocks.image-before-slide.settings.title.label"
        },
        {
          "type": "select",
          "id": "label_size",
          "label": "t:sections.compare_slider.settings.label_size.label",
          "options": [
            {
              "value": "h6",
              "label": "XS"
            },
            {
              "value": "h5",
              "label": "S"
            },
            {
              "value": "h4",
              "label": "M"
            },
            {
              "value": "h3",
              "label": "L"
            },
            {
              "value": "h2",
              "label": "XL"
