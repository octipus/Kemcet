{%- if section.settings.title != blank -%}
  <link rel="stylesheet" href="{{- 'main-404.css' | asset_url -}}" media="print" onload="this.media='all'">
  {%- render 'section-common-styles', section: section -%}
  <noscript>
    {{- 'main-404.css' | asset_url | stylesheet_tag -}}
  </noscript>

  <div class="main-404 color-{{ section.settings.color_scheme }}">
    <div class="container max-w-{{ section.settings.section_width }} center">
      <h1 class="main-404__title h1">{{- section.settings.title -}}</h1>

      {%- if section.settings.subtext != blank -%}
        <p class="main-404__subtext font-size-md">
          {{- section.settings.subtext -}}
        </p>
      {%- endif -%}

      {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
        {%- assign value = section.settings.link_text -%}
        {%- render 'button', type: 'link', value: value, href: section.settings.link_url, class: 'button' -%}
        {%- assign value = nil -%}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.main-404.name",
  "tag": "section",
  "class": "section-main-404",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.main-404.settings.title.label",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "t:sections.main-404.settings.subtext.label"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.main-404.settings.link_text.label",
      "default": "Continue shopping"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "t:sections.main-404.settings.link_url.label",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "t:global.header.settings.content",
      "info": "t:global.header.settings.info"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:global.settings.section.width.label",
      "options": [
        {
          "value": "page",
          "label": "t:global.settings.section.width.options.page.label"
        },
        {
          "value": "fluid",
          "label": "t:global.settings.section.width.options.fluid.label"
        },
        {
          "value": "full",
          "label": "t:global.settings.section.width.options.full.label"
        }
      ],
      "default": "page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "t:global.settings.spacing.top.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:global.settings.spacing.bottom.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "section_border",
      "label": "t:global.settings.section.border.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.settings.section.border.options.none.label"
        },
        {
          "value": "top",
          "label": "t:global.settings.section.border.options.top.label"
        },
        {
          "value": "bottom",
          "label": "t:global.settings.section.border.options.bottom.label"
        },
        {
          "value": "both",
          "label": "t:global.settings.section.border.options.both.label"
        }
      ],
      "default": "none"
    }
  ]
}
{% endschema %}
