{{- 'section-main-list-collections.css' | asset_url | stylesheet_tag -}}
{{- 'component-card-collection.css' | asset_url | stylesheet_tag -}}
{%- render 'section-common-styles', section: section -%}

{% style %}
  .main-list-collections__grid {
    column-gap: {{ settings.spacing_mobile }}rem;
  }
  @media screen and (min-width: 990px) {
    .main-list-collections__grid {
      column-gap: {{ settings.spacing_desktop }}rem;
    }
  }
{% endstyle %}

<script src="{{- 'collection-load-more.js' | asset_url -}}" defer="defer"></script>
<script src="{{- 'collection-load-previous.js' | asset_url -}}" defer="defer"></script>

<div class="main-list-collections color-{{ section.settings.color_scheme }} gradient isolate">
  <div class="container max-w-{{ section.settings.section_width }}" id="ProductGridContainer">
    {%- case section.settings.collections_to_show -%}
      {%- when 'all' -%}
        {%- paginate collections by section.settings.collections_per_page -%}
          {%- if paginate.previous and section.settings.pagination_style == 'load_more'-%}
            <collection-load-previous class="main-list-collections__actions  main-list-collections__actions--previous text-center no-js-hidden{% unless paginate.previous %} hidden{% endunless %}" data-current-page="{{- paginate.current_page -}}">
              {%- liquid
                assign load_previous_button_data_href = 'data-href="' | append: paginate.previous.url | append: '"'
                assign load_previous_value = 'collection.load_previous' | t

                render 'button', class: 'button js-btn-load-previous', button_style: section.settings.button_style, attr: load_previous_button_data_href, value: load_previous_value, loading_spinner: true
              -%}
            </collection-load-previous>
          {%- endif -%}
          <div class="main-list-collections__grid" id="product-grid">
            {%- liquid
              for collection in collections
                assign card_classes = 'color-' | append: section.settings.color_scheme_for_collection_cards
                render 'card-collection', collection_ref: collection, class: card_classes
              endfor
            -%}
          </div>
          {%- if paginate.pages > 1 -%}
            {%  if section.settings.pagination_style == 'load_more' %}
            <collection-load-more class="main-list-collections__actions text-center no-js-hidden{% unless paginate.next %} hidden{% endunless %}" data-current-page="{{- paginate.current_page -}}">
              {%- liquid
                assign load_more_button_data_href = 'data-href="' | append: paginate.next.url | append: '"'
                assign load_more_value = 'collection.ajax_button' | t
                render 'button', class: 'button js-btn-load-more', button_style: 'button--filled', attr: load_more_button_data_href, value: load_more_value, loading_spinner: true
              -%}
            </collection-load-more>
          {% else %}
              <div class="main-list-collections__actions">
                {%- render 'pagination', paginate: paginate, anchor: '' -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endpaginate -%}
      {%- when 'selected' -%}
        <div class="main-list-collections__grid" id="product-grid">
          {%- liquid
            for block in section.blocks
              assign card_classes = 'color-' | append: block.settings.color_scheme
              render 'card-collection', collection_ref: block.settings.collection, title: block.settings.title, image: block.settings.image, class: card_classes
            endfor
          -%}
        </div>
    {%- endcase -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-list-collections.name",
  "tag": "section",
  "class": "section-main-list-collections",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-list-collections.settings.header_collections.content"
    },
    {
      "type": "radio",
      "id": "collections_to_show",
      "label": "t:sections.main-list-collections.settings.collections_to_show.label",
      "options": [
        {
          "value": "all",
          "label": "t:sections.main-list-collections.settings.collections_to_show.options__1.label"
        },
        {
          "value": "selected",
          "label": "t:sections.main-list-collections.settings.collections_to_show.options__2.label"
        }
      ],
      "default": "all"
    },
    {
      "type": "select",
      "id": "pagination_style",
      "label": "t:sections.global.settings.pagination.style.label",
      "options": [
        {
          "value": "default",
          "label": "t:sections.global.settings.pagination.style.options.default.label"
        },
        {
          "value": "load_more",
          "label": "t:sections.global.settings.pagination.style.options.load_more.label"
        }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "t:sections.main-list-collections.settings.header_collections_grid.content"
    },
    {
      "type": "range",
      "id": "collections_per_page",
      "min": 3,
      "max": 50,
      "step": 1,
      "label": "t:sections.main-list-collections.settings.collections_per_page.label",
      "info": "t:sections.main-list-collections.settings.collections_per_page.info",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_for_collection_cards",
      "label": "t:sections.main-list-collections.settings.color_scheme_for_collection_cards.label",
      "info": "t:sections.main-list-collections.settings.color_scheme_for_collection_cards.info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:global.header.settings.content",
      "info": "t:global.header.settings.info"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:global.settings.section.width.label",
      "options": [
        {
          "value": "page",
          "label": "t:global.settings.section.width.options.page.label"
        },
        {
          "value": "fluid",
          "label": "t:global.settings.section.width.options.fluid.label"
        }
      ],
      "default": "page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "t:global.settings.spacing.top.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:global.settings.spacing.bottom.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "section_border",
      "label": "t:global.settings.section.border.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.settings.section.border.options.none.label"
        },
        {
          "value": "top",
          "label": "t:global.settings.section.border.options.top.label"
        },
        {
          "value": "bottom",
          "label": "t:global.settings.section.border.options.bottom.label"
        },
        {
          "value": "both",
          "label": "t:global.settings.section.border.options.both.label"
        }
      ],
      "default": "none"
    }
  ],
  "max_blocks": 50,
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.main-list-collections.blocks.collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.main-list-collections.blocks.collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.main-list-collections.blocks.collection.settings.image.label",
          "info": "t:sections.main-list-collections.blocks.collection.settings.image.info"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "t:sections.main-list-collections.blocks.collection.settings.title.label",
          "info": "t:sections.main-list-collections.blocks.collection.settings.title.info"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:sections.global.element.heading_size.label",
          "options": [
            {
              "value": "h6",
              "label": "XS"
            },
            {
              "value": "h5",
              "label": "S"
            },
            {
              "value": "h4",
              "label": "M"
            },
            {
              "value": "h3",
              "label": "L"
            },
            {
              "value": "h2",
              "label": "XL"
            }
          ],
          "default": "h2"
        },
        {
          "type": "header",
          "content": "t:global.header.settings.content",
          "info": "t:global.header.settings.info"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:global.settings.color_scheme.label",
          "default": "scheme-1"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-list-collections.name"
    }
  ]
}
{% endschema %}
