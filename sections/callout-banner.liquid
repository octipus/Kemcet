{{- 'section-callout-banner.css' | asset_url | stylesheet_tag -}}
{%- render 'section-common-styles', section: section -%}

{%- capture countdown_timer_container_media_additional_classes -%}
  {% if section.settings.layout == 'image_none' %}
    callout-banner__container-media-no-image
  {% endif %}
  {% if section.settings.layout == 'image' %}
    callout-banner__container-media-image
  {% endif %}
{%- endcapture -%}

{%- capture countdown_timer_container_additional_classes -%}
  {% if section.settings.layout == 'image_none' %}
    callout-banner__container-no-image
  {% endif %}
  {% if section.settings.layout == 'image' %}
    callout-banner__container-image
  {% endif %}
  {%- if section.settings.button_url == blank or section.settings.button_text == blank -%}
    callout-banner__container-no-button
  {% endif %}
{%- endcapture -%}
{% if section.settings.show_borders %}
  {% style %}
    .section-callout-banner .countdown-timer__columns {
      border-block: 0.1rem solid rgba(var(--color-border), var(--alpha-border));
    }
    @media screen and (min-width: 750px) {
      .section-callout-banner .countdown-timer__columns {
        border-inline: 0.1rem solid rgba(var(--color-border), var(--alpha-border));
        border-block: none;
      }
    }
  {% endstyle %}
{% endif %}

<div class='color-{{ section.settings.color_scheme }} gradient isolate section section-new overflow-hidden js-animation-fade-in'>
  <div class='container max-w-{{ section.settings.section_width }} {% if section.settings.section_width == 'full' and section.settings.layout == 'image' %} callout-banner__container-media-fullwidth{% endif %}'>
    <div class='callout-banner__container-media {{ countdown_timer_container_media_additional_classes | strip }}'>
      <div class='callout-banner__container {{ countdown_timer_container_additional_classes | strip }}'>

        <div class='callout-banner__header-container'>
          <h3 class='callout-banner__title heading-static {{ section.settings.heading_size }}'>
            {{ section.settings.heading }}
          </h3>
          <p class='callout-banner__subtitle'>
            {{ section.settings.text }}
          </p>
        </div>

        {%- unless section.settings.layout == 'image' -%}
          {%- render 'countdown-timer',
            id: section.id,
            class: '',
            column_type: 'col'
            timer_text_first_letter: false,
            timer_year: section.settings.timer_year,
            timer_month: section.settings.timer_month,
            timer_day: section.settings.timer_day,
            timer_hour: section.settings.timer_hour,
            timer_minute: section.settings.timer_minute,
            timer_extend: section.settings.timer_extend,
            show_timer_days: section.settings.show_timer_days,
            show_timer_hours: section.settings.show_timer_hours,
            show_timer_minutes: section.settings.show_timer_minutes,
            show_timer_seconds: section.settings.show_timer_seconds,
            timer_end_message: section.settings.timer_end_message
          -%}
        {% endunless %}

        {%- if section.settings.button_url != blank and section.settings.button_text != blank and section.settings.action_preference == 'button' -%}
          <div class='callout-banner__button-container'>
            <div class='callout-banner__button-wrapper'>
              {%- render 'button', type: 'link', class: 'button button--auto custom_class {{ section_button_classes | strip }}', button_style: section.settings.button_style, value: section.settings.button_text, href: section.settings.button_url -%}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.newsletter_button_label != blank and section.settings.action_preference == 'newsletter_form' -%}
          <div class="callout-banner__newsletter-form">
            {%- render 'newsletter-form', namespace: section.id, js_class: 'js-form', submit_button_text: section.settings.newsletter_button_label, success_message: section.settings.newsletter_success_message -%}
          </div>
        {%- endif -%}
      </div>

      {%- unless section.settings.layout == 'image_none' -%}
        <div class='callout-banner__image-container'>
          {%- liquid
            if section.settings.image != blank
              assign image_class = 'callout-banner__image'
              if section.settings.image_mobile != blank
                assign image_class = image_class | append: ' callout-banner__image--desktop'
              endif
              render 'image', image: section.settings.image, alt: section.settings.image.alt | escape, class: image_class
            else
              echo 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg'
            endif
            if section.settings.image_mobile != blank
              render 'image', image: section.settings.image_mobile, alt: section.settings.image_mobile.alt | escape, class: 'callout-banner__image callout-banner__image--mobile'
            endif
          -%}
        </div>
      {% endunless %}

    </div>
  </div>
</div>
