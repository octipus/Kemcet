{{- 'form-contact.css' | asset_url | stylesheet_tag -}}
{%- render 'section-common-styles', section: section -%}

<div class="form-contact color-{{ section.settings.color_scheme }}">
  <div class="container max-w-{{ section.settings.section_width }}">
    {%- form 'contact', id: 'ContactForm' -%}
      {%- if form.posted_successfully? -%}
        <h3 class="h4" tabindex="-1" autofocus>{{- 'contact.form.success' | t -}}</h3>
      {%- elsif form.errors -%}
        <div class="color-red">
          {{- form.errors | default_errors -}}
        </div>
      {%- endif -%}

      <div class="form-row form-row--double">
        {%-
          liquid
          assign label = 'contact.form.name' | t
          assign placeholder = 'contact.form.name' | t
          capture attr
            echo 'autocomplete="name"'
          endcapture
          if form.name
            assign value = form.name
          elsif customer
            assign value = customer.name
          else
            assign value = ''
          endif
          render 'text-input', id: 'ContactForm-name', label: label, name: 'contact[Name]', placeholder: placeholder, attr: attr, value: value
        -%}

        {%-
          liquid
          assign label = 'contact.form.email' | t | append: ' <span class="color-red" aria-hidden="true">*</span>'
          assign placeholder = 'contact.form.email' | t
          capture attr
            echo 'autocomplete="email"'
            echo 'spellcheck="false"'
            echo 'autocapitalize="off"'
            echo 'aria-required="true"'
          endcapture
          if form.email
            assign value = form.email
          elsif customer
            assign value = customer.email
          else
            assign value = ''
          endif
          if form.errors contains 'email'
            assign error = form.errors.translated_fields['email'] | capitalize | append: ' ' | append: form.errors.messages['email']
            assign has_error = true
          endif
          render 'text-input', id: 'ContactForm-email', type: 'email', label: label, name: 'contact[email]', placeholder: placeholder, attr: attr, value: value, has_error: has_error, message: error
        -%}
      </div>

      <div class="form-row">
        {%-
          liquid
          assign label = 'contact.form.message' | t
          assign placeholder = 'contact.form.message' | t
          render 'textarea-input', id: 'ContactForm-body', label: label, name: 'contact[message]', placeholder: placeholder, body: form.body
        -%}
      </div>

      <div class="form-row form-row--actions">
        {%- assign value = 'actions.submit' | t -%}
        {%- render 'button', type: 'submit', style: 'solid', value: value, class: 'button' -%}
        {%- assign value = nil -%}
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.form-contact.name",
  "tag": "section",
  "class": "section--contact-form",
  "settings": [
    {
      "type": "header",
      "content": "t:global.header.settings.content",
      "info": "t:global.header.settings.info"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:global.settings.section.width.label",
      "options": [
        {
          "value": "narrower",
          "label": "t:global.settings.section.width.options.narrower.label"
        },
        {
          "value": "narrow",
          "label": "t:global.settings.section.width.options.narrow.label"
        },
        {
          "value": "page",
          "label": "t:global.settings.section.width.options.page.label"
        }
      ],
      "default": "narrower"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "t:global.settings.spacing.top.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:global.settings.spacing.bottom.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "section_border",
      "label": "t:global.settings.section.border.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.settings.section.border.options.none.label"
        },
        {
          "value": "top",
          "label": "t:global.settings.section.border.options.top.label"
        },
        {
          "value": "bottom",
          "label": "t:global.settings.section.border.options.bottom.label"
        },
        {
          "value": "both",
          "label": "t:global.settings.section.border.options.both.label"
        }
      ],
      "default": "none"
    }
  ]
}
{% endschema %}
