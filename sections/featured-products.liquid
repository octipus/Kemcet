{%- liquid
  assign products_array = blank
  if section.blocks.size > 0
    assign products_array = true
  endif
  render 'products-feed', section: section, products_array: products_array, section_name: 'featured-products', section_blocks: section.blocks
-%}

{% schema %}
{
  "name": "t:sections.featured-products.name",
  "tag": "section",
  "class": "section-new section--featured-products",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.global.settings.layout.label",
      "options": [
        {
          "value": "layout-1",
          "label": "t:sections.global.settings.layout.options.layout_1.label"
        },
        {
          "value": "layout-2",
          "label": "t:sections.global.settings.layout.options.layout_2.label"
        }
      ],
      "default": "layout-1",
      "info": "t:sections.global.settings.layout.info"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.global.element.heading.label",
      "default": "Heading for Featured Products"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.global.element.heading_size.label",
      "options": [
        {
          "value": "h6",
          "label": "XS"
        },
        {
          "value": "h5",
          "label": "S"
        },
        {
          "value": "h4",
          "label": "M"
        },
        {
          "value": "h3",
          "label": "L"
        },
        {
          "value": "h2",
          "label": "XL"
        }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.products-feed.settings.button_text.label",
      "info": "t:sections.products-feed.settings.button_text.info",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.products-feed.settings.button_url.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.global.settings.button_style.label",
      "options": [
        {
          "value": "button--filled",
          "label": "t:sections.global.settings.button_style.options.filled.label"
        },
        {
          "value": "button--outlined",
          "label": "t:sections.global.settings.button_style.options.outlined.label"
        },
        {
          "value": "button--link",
          "label": "t:sections.global.settings.button_style.options.default.label"
        }
      ],
      "default": "button--filled"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "t:sections.featured-products.blocks.collection.settings.max_products.label",
      "default": 8
    },
    {
      "type": "header",
      "content": "t:global.header.settings.content",
      "info": "t:global.header.settings.info"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:global.settings.section.width.label",
      "options": [
        {
          "value": "page",
          "label": "t:global.settings.section.width.options.page.label"
        },
        {
          "value": "fluid",
          "label": "t:global.settings.section.width.options.fluid.label"
        }
      ],
      "default": "page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "t:global.settings.spacing.top.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:global.settings.spacing.bottom.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "section_border",
      "label": "t:global.settings.section.border.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.settings.section.border.options.none.label"
        },
        {
          "value": "top",
          "label": "t:global.settings.section.border.options.top.label"
        },
        {
          "value": "bottom",
          "label": "t:global.settings.section.border.options.bottom.label"
        },
        {
          "value": "both",
          "label": "t:global.settings.section.border.options.both.label"
        }
      ],
      "default": "none"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.featured-products.blocks.collection.name",
      "settings": [
        {
          "type": "product_list",
          "id": "products",
          "label": "t:sections.products-feed.settings.products.label",
          "info": "t:sections.products-feed.settings.products.info",
          "limit": 12
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.featured-products.blocks.collection.settings.collection.label",
          "info": "t:sections.featured-products.blocks.collection.settings.collection.info"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "t:sections.featured-products.blocks.collection.settings.title.label",
          "info": "t:sections.featured-products.blocks.collection.settings.title.info"
        },
        {
          "type": "checkbox",
          "id": "show_unavailable_products",
          "label": "t:sections.featured-products.blocks.collection.settings.show_unavailable_products.label",
          "info": "t:sections.featured-products.blocks.collection.settings.show_unavailable_products.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-products.name",
      "settings": {
        "heading": "Heading for Featured Products"
      },
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "collection": "all-products"
          }
        }
      ]
    }
  ]
}
{% endschema %}
