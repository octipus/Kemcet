{{- 'component-search-hero.css' | asset_url | stylesheet_tag -}}
{%- render 'section-common-styles', section: section -%}

{% style %}
  {%- if settings.enable_breadcrumbs_on_other_pages -%}
    .search-hero .breadcrumbs {
      position: unset;
      width: unset;
      margin-block-end: 2.4rem;
    }
    @media screen and (min-width: 750px) {
      .search-hero__title {
        margin-block-start: 4.8rem;
      }
      .search-hero .breadcrumbs {
        position: absolute;
        width: calc(100% - var(--page-gutter) * 2);
        margin-block-end: 0;
      }
    }
  {%- endif -%}
  {%- if section.settings.spacing_top == '0' -%}
    .search-hero .breadcrumbs {
      position: unset;
      width: unset;
    }
  {%- endif -%}
{% endstyle %}

<div class="search-hero color-{{ section.settings.color_scheme }} gradient isolate">
  <div class="container">
    {%- if settings.enable_breadcrumbs_on_other_pages -%}
      {%- render 'breadcrumbs', alignment: 'center'-%}
    {%- endif -%}

    <h1 class="search-hero__title">
      {%- if search.performed -%}
        <span class="search-hero__title-small h4">
          {{- 'search.results_with_count' | t: count: search.results_count -}}
        </span>
        <span>
          {{- 'search.results_term' | t: terms: search.terms -}}
        </span>
      {%- else -%}
        {{- 'search.empty' | t -}}
      {%- endif -%}
    </h1>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-search-banner.name",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:global.header.settings.content",
      "info": "t:global.header.settings.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "t:global.settings.spacing.top.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:global.settings.spacing.bottom.label",
      "options": [
        {
          "value": "0",
          "label": "t:global.settings.spacing.options.none.label"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "section_border",
      "label": "t:global.settings.section.border.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.settings.section.border.options.none.label"
        },
        {
          "value": "top",
          "label": "t:global.settings.section.border.options.top.label"
        },
        {
          "value": "bottom",
          "label": "t:global.settings.section.border.options.bottom.label"
        },
        {
          "value": "both",
          "label": "t:global.settings.section.border.options.both.label"
        }
      ],
      "default": "none"
    }
  ]
}
{% endschema %}
