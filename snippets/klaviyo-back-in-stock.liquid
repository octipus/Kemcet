{% comment %}
  Klaviyo Back in Stock: loads onsite.js and binds the .klaviyo-bis-trigger button.
  Must render after the trigger exists in the DOM (e.g. end of main-product).
{% endcomment %}
{% if settings.klaviyo_api_key != blank %}
  <script>
    window.__klaviyoBisApiKey = {{ settings.klaviyo_api_key | json }};
  </script>
  <script src="https://a.klaviyo.com/media/js/onsite/onsite.js"></script>
  <script>
    (function () {
      if (window.__klaviyoBisBooted) {
        return;
      }
      window.__klaviyoBisBooted = true;

      var account = {{ settings.klaviyo_api_key | json }};

      function initKlaviyoBackInStock() {
        var k = window.klaviyo || [];
        k.init({ account: account, platform: 'shopify' });
        k.enable('backinstock', {
          trigger: {
            product_page_text: 'Notify Me When Available',
            product_page_class: 'klaviyo-bis-trigger',
            product_page_text_align: 'center',
            product_page_margin: '0px',
            replace_anchor: false
          },
          modal: {
            headline: '{product_name}',
            body_content:
              '{{ settings.bis_body_content }}',
            email_field_label: 'Email',
            button_label: '{{ settings.bis_button_text }}',
            subscription_success_label: "{{ settings.bis_success_message }}",
            footer_content: '',
            additional_styles:
              "@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap');",
            drop_background_color: '#121212',
            background_color: '#fafafa',
            text_color: '#121212',
            button_text_color: '#fafafa',
            button_background_color: '#121212',
            close_button_color: '#ccc',
            error_background_color: '#fcd6d7',
            error_text_color: '#C72E2F',
            success_background_color: '#d3efcd',
            success_text_color: '#1B9500'
          }
        });
      }

      function getProductForm() {
        return document.querySelector('product-form');
      }

      function getPurchaseTargets(productForm) {
        if (!productForm) return [];
        var form = productForm.querySelector('form[action*="/cart/add"]');
        var els = [];
        if (form) {
          form.querySelectorAll('button[name="add"]').forEach(function (btn) {
            els.push(btn);
          });
          form
            .querySelectorAll(
              '.shopify-payment-button, [data-shopify="payment-button"], .additional-checkout-buttons'
            )
            .forEach(function (node) {
              els.push(node);
            });
        }
        var sticky = productForm.querySelector('product-sticky-atc');
        if (sticky) els.push(sticky);
        return els;
      }

      function getVariantSnapshot() {
        var productForm = getProductForm();
        var form = productForm && productForm.querySelector('form[action*="/cart/add"]');
        var idInput = form && form.querySelector('input[name="id"]');
        var jsonEl = document.querySelector(
          'product-selector script[type="application/json"]'
        );

        if (!form || !idInput) return null;

        var id = parseInt(idInput.value, 10);
        if (Number.isNaN(id)) return null;

        if (jsonEl) {
          try {
            var variants = JSON.parse(jsonEl.textContent);
            var match = variants.find(function (v) {
              return v.id === id;
            });
            if (match) return match;
          } catch (e) {}
        }

        var submit = form.querySelector('button[name="add"]');
        return {
          id: id,
          available: !(submit && submit.hasAttribute('disabled'))
        };
      }

      function updateButtonVisibility(variant) {
        var productForm = getProductForm();
        var trigger = document.querySelector('.klaviyo-bis-trigger');
        if (!trigger) return;

        var isOutOfStock = !variant || variant.available === false;

        getPurchaseTargets(productForm).forEach(function (el) {
          el.style.display = isOutOfStock ? 'none' : '';
        });

        trigger.style.display = isOutOfStock ? '' : 'none';
        trigger.setAttribute('aria-hidden', isOutOfStock ? 'false' : 'true');
      }

      function boot() {
        initKlaviyoBackInStock();
        updateButtonVisibility(getVariantSnapshot());

        document.addEventListener('variant:change', function (event) {
          var detail = event.detail || {};
          var variant = 'variant' in detail ? detail.variant : getVariantSnapshot();
          updateButtonVisibility(variant);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
      } else {
        boot();
      }
    })();
  </script>
{% endif %}
